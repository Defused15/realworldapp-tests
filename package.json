{
  "name": "realworldapp-tests",
  "version": "1.0.0",
  "description": "Playwright E2E test suite for RealWorld app",
  "main": "index.js",
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "husky",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:security": "playwright test --grep @security",
    "test:contract": "playwright test --grep @contract",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:performance": "playwright test --grep @performance",
    "test:staging": "NODE_ENV=staging playwright test",
    "test:production": "NODE_ENV=production playwright test",
    "test:db": "vitest run",
    "test:db:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:mutation": "stryker run",
    "test:all": "npm run test:unit && npm run test:db && playwright test",
    "db:seed": "npx tsx tests/scripts/seed.ts",
    "db:reset": "npx tsx tests/scripts/teardown.ts",
    "perf:smoke": "PROFILE=smoke k6 run perf/k6/scenarios/home.js",
    "perf:load": "PROFILE=load k6 run perf/k6/scenarios/home.js",
    "perf:stress": "PROFILE=stress k6 run perf/k6/scenarios/home.js",
    "perf:spike": "PROFILE=spike k6 run perf/k6/scenarios/home.js",
    "perf:smoke:grafana": "PROFILE=smoke k6 run -o experimental-prometheus-rw perf/k6/scenarios/home.js",
    "perf:load:grafana": "PROFILE=load k6 run -o experimental-prometheus-rw perf/k6/scenarios/home.js",
    "lighthouse": "lhci autorun",
    "security:zap": "docker run --rm --network host -v \"$PWD/security/zap:/zap/wrk:rw\" ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -t \"${BASE_URL:-http://localhost:3000}\" -c rules.tsv -I",
    "security:deps": "trivy fs --include-dev-deps --config security/trivy/trivy.yaml .",
    "security:secrets": "gitleaks detect --source . --config .gitleaks.toml --redact --verbose",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "overrides": {
    "tmp": "^0.2.6"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "gts fix",
      "gts lint"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^9.0.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-playwright": "^2.10.4",
    "gts": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
