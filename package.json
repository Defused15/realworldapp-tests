{
  "name": "realworldapp-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E test suite for RealWorld app",
  "main": "index.js",
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "husky",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:security": "playwright test --grep @security",
    "test:contract": "playwright test --grep @contract",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:performance": "playwright test --grep @performance",
    "test:staging": "NODE_ENV=staging playwright test",
    "test:production": "NODE_ENV=production playwright test",
    "test:db": "vitest run",
    "test:db:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:mutation": "stryker run",
    "test:all": "npm run test:unit && npm run test:db && playwright test",
    "db:seed": "npx tsx tests/scripts/seed.ts",
    "db:reset": "npx tsx tests/scripts/teardown.ts",
    "flaky:summary": "npx tsx tests/scripts/flaky-summary.ts",
    "test:quarantine": "playwright test --grep @quarantine",
    "perf": "k6 run perf/k6/scenarios/${SCENARIO:-home}.js",
    "perf:smoke": "PROFILE=smoke npm run perf",
    "perf:load": "PROFILE=load npm run perf",
    "perf:stress": "PROFILE=stress npm run perf",
    "perf:spike": "PROFILE=spike npm run perf",
    "perf:all": "for s in home signin transaction; do SCENARIO=$s PROFILE=${PROFILE:-smoke} npm run perf || exit 1; done",
    "perf:all:smoke": "for s in home signin transaction signup; do SCENARIO=$s PROFILE=smoke npm run perf || exit 1; done",
    "perf:smoke:grafana": "PROFILE=smoke K6_PROMETHEUS_RW_TREND_AS_NATIVE_HISTOGRAM=true k6 run -o experimental-prometheus-rw perf/k6/scenarios/${SCENARIO:-home}.js",
    "perf:load:grafana": "PROFILE=load K6_PROMETHEUS_RW_TREND_AS_NATIVE_HISTOGRAM=true k6 run -o experimental-prometheus-rw perf/k6/scenarios/${SCENARIO:-home}.js",
    "lighthouse": "lhci autorun",
    "security:zap": "docker run --rm --network host -v \"$PWD/security/zap:/zap/wrk:rw\" ghcr.io/zaproxy/zaproxy:stable zap-baseline.py -t \"${BASE_URL:-http://localhost:3000}\" -c rules.tsv -I",
    "security:deps": "trivy fs --include-dev-deps --config security/trivy/trivy.yaml .",
    "security:secrets": "gitleaks detect --source . --config .gitleaks.toml --redact --verbose",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "overrides": {
    "tmp": "^0.2.6"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "gts fix",
      "gts lint"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^10.4.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-playwright": "^2.10.4",
    "gts": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
